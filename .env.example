# =============================================================================
#  가재코드(GJC) API 키 — 여기에 키만 채워라.  (작성: 2026-06-28)
# -----------------------------------------------------------------------------
#  로드 방법 (★중요★ gjc 는 cwd(프로젝트) .env 의 키는 보안상 "의도적으로 무시"한다.
#  반드시 신뢰 위치에서 읽혀야 한다. 이 레포 .env 를 ~/.gjc/.env 로 심링크해 둠:
#       ln -sf /home/devswha/workspace/oh-my-gjc/.env ~/.gjc/.env   # (이미 설정됨)
#  → 이 파일에 키만 채우면 gjc 가 자동으로 읽는다. source 도, 셸 재시작도 불필요.
#  (gjc 자격증명 우선순위: 라이브env → ~/.gjc/agent/.env → ~/.gjc/.env → ~/.env.
#   프로젝트 cwd/.env 는 자격증명으로는 무시됨.)
#
#  현재 실측 상태(설정 완료):
#     - 모델(전부 키 불필요·검증됨): Claude Max + OpenAI Codex(Pro) + Kimi(K2.7)
#             최고품질: gjc --mpreset claude-max  (Opus 4.8 xhigh)
#             일꾼/병렬: gjc --mpreset kimi        (이미 로그인됨, 추가구독 불필요)
#     - 검색: providers.webSearch=exa → Exa 작동 검증됨 (폴백 duckduckgo)
#     - Gemini: google/gemini-3-flash-preview 작동 검증됨
#
#  *** 이 파일은 절대 커밋 금지 (.gitignore 에 .env 등록됨). 실키 = 비밀. ***
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
#  1순위 · 검색 (가장 큰 성능 구멍 — 여기부터 채워라)
# ─────────────────────────────────────────────────────────────────────────────

# Exa — 코드/문서/시맨틱 검색 품질 최고. 무료 1,000/월, 이후 표준 $7/1k.
#   발급: https://exa.ai  (Dashboard → API Keys)
#   추천: 기본 검색을 Exa 로.  gjc config set providers.webSearch exa
EXA_API_KEY=

# Tavily — LLM 에이전트 전용. 무료 1,000 크레딧/월(카드 불필요). 폴백/대체용.
#   발급: https://tavily.com
TAVILY_API_KEY=

# Perplexity — 합성 답변/최신성.
#   (A) API 키:  https://www.perplexity.ai/settings/api   (Sonar, 요청당 과금)
PERPLEXITY_API_KEY=
#   (B) 또는 Perplexity Pro 구독이 있으면 세션 쿠키로 키리스 사용:
#       브라우저 perplexity.ai 로그인 → 쿠키 문자열 붙여넣기
PERPLEXITY_COOKIES=

# Brave — 범용. ’26.2 무료티어 폐지($5/1k). 우선순위 낮음.
BRAVE_API_KEY=

# Kagi — 고품질·프리미엄($15~25/1k). 보통 과함.
KAGI_API_KEY=

# Jina — 보조 검색/리더.
JINA_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
#  2순위 · 모델 프로바이더 (선택 — Claude/Codex 는 이미 OAuth 로 동작, 키 불필요)
# ─────────────────────────────────────────────────────────────────────────────

# Gemini — 품질 점프는 아니고 싼 유틸. 1M 컨텍스트 + 초저가 flash(smol 역할).
#   무료 티어 있음.  발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 아래는 보통 불필요(이미 구독 OAuth 로 커버). 직접 API 과금하려면만 채워라.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
ZAI_API_KEY=
MINIMAX_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
#  키 채운 뒤 (source 불필요 — 심링크로 gjc 가 자동으로 읽음)
# ─────────────────────────────────────────────────────────────────────────────
#  검색 설정은 이미 적용됨:
#     providers.webSearch=exa,  web_search.fallback=["duckduckgo"]
#  새 키 추가 후 검증:
#     gjc web-search "test query" --limit 2 --compact     # Provider: Exa 확인
#  심층 조사 모드 켜려면(비용↑):  gjc config set exa.enableResearcher true
